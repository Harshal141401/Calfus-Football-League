# Copy this file to ".env" and fill in your own values. NEVER commit .env to git.
# IMPORTANT: use a NEWLY ROTATED Mongo password — URL-encode it ("@" -> %40,
# so a password like  NewPass@99  becomes  NewPass%4099).

# --- MongoDB ---
MONGODB_URI=mongodb+srv://USERNAME:URL_ENCODED_PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority&appName=YOUR_APP
DB_NAME=promptwars
COLLECTION=employeeDetails

# --- HTTP ---
PORT=4000

# --- Auth / sessions ---
# Long random string used to sign session tokens. Generate one, keep it secret.
SESSION_SECRET=change-me-to-a-long-random-string
SESSION_TTL_HOURS=12
# Header key for admin routes via curl (X-Admin-Key). Leave blank to disable.
ADMIN_KEY=
# Password for the in-browser admin login (Admin tab). Falls back to ADMIN_KEY if blank.
ADMIN_PASSWORD=

# --- Prediction timing ---
# Predictions are open all the time; each fixture locks this many minutes before
# its own kickoff (e.g. a 10:30 kickoff closes at 10:00).
LOCK_BEFORE_MIN=30
# Fixture date+time strings are kickoff-in-this-tz (dashboard data is IST).
FIXTURE_TZ=Asia/Kolkata

# --- Scoring (defaults match the brief; override if rules change) ---
POINTS_WIN_CORRECT=3
POINTS_WIN_WRONG=-1
POINTS_SCORE_CORRECT=5
POINTS_SCORE_WRONG=-2

# --- Optional football API proxy ---
WC_BASE=https://worldcup26.ir
WC_TOKEN=
