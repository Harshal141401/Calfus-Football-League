# Copy this file to ".env" and fill in your own values. Never commit .env.
# IMPORTANT: use a NEWLY ROTATED Mongo password — URL-encode it ("@" -> %40).

# --- MongoDB ---
MONGODB_URI=mongodb+srv://USERNAME:URL_ENCODED_PASSWORD@clusterpromptwars.z59xnob.mongodb.net/?retryWrites=true&w=majority&appName=ClusterPromptWars
DB_NAME=employeeDetails
COLLECTION=promptWars

# --- HTTP ---
PORT=4000

# --- Auth / sessions ---
# Long random string used to sign session tokens. Generate one, keep it secret.
SESSION_SECRET=change-me-to-a-long-random-string
SESSION_TTL_HOURS=12
# Header key for admin routes via curl (X-Admin-Key). Leave blank to disable.
ADMIN_KEY=
# Password for the in-browser admin login (Admin tab). Falls back to ADMIN_KEY if blank.
ADMIN_PASSWORD=

# --- Prediction window (timezone-aware; common US+IST slot is TBD) ---
# Days predictions may be submitted (luxon weekday: Mon=1 ... Sun=7).
PREDICTION_DAYS=1,4
# Open hours on those days, in WINDOW_TZ. HH:mm. Start inclusive, end exclusive.
WINDOW_TZ=Asia/Kolkata
WINDOW_START=10:00
WINDOW_END=18:00
# Coverage runs until the NEXT prediction day at this early-morning cutoff (IST):
# Monday covers matches up to Thursday COVERAGE_END_TIME; Thursday up to Monday.
COVERAGE_END_TIME=06:00
# Fixture date+time strings are kickoff-in-this-tz (dashboard data is IST).
FIXTURE_TZ=Asia/Kolkata

# --- Scoring (defaults match the brief; override if rules change) ---
POINTS_WIN_CORRECT=3
POINTS_WIN_WRONG=-1
POINTS_SCORE_CORRECT=5
POINTS_SCORE_WRONG=-2

# --- Optional football API proxy ---
WC_BASE=https://worldcup26.ir
WC_TOKEN=
