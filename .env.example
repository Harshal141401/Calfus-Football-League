# Copy this file to ".env" and fill in your own values.
# IMPORTANT: use a NEWLY ROTATED password — the one shared in chat is compromised.
# Never commit .env to git.

# Your Atlas connection string. Note: put your real (rotated) password here,
# URL-encoded. "@" becomes %40, so a password like  NewPass@99  ->  NewPass%4099
MONGODB_URI=mongodb+srv://USERNAME:URL_ENCODED_PASSWORD@clusterpromptwars.z59xnob.mongodb.net/?retryWrites=true&w=majority&appName=ClusterPromptWars

# Which database / collection the employees live in
DB_NAME=employeeDetails
COLLECTION=promptWars

PORT=4000

# Optional: only needed if the football API's /get/* routes require a token
WC_BASE=https://worldcup26.ir
WC_TOKEN=
